# ─────────────────────────────────────────────────────────────────────────────
# LGS — Environment variables
# Copy this file to .env and fill in real secrets before running `make up`.
# .env is git-ignored; .env.example is committed as the canonical template.
# ─────────────────────────────────────────────────────────────────────────────

# ── PostgreSQL ────────────────────────────────────────────────────────────────
DB_NAME=lgs_core
DB_USER=lgs_user
DB_PASSWORD=lgs_secure_password_change_me   # CHANGE IN PRODUCTION
DB_SSLMODE=disable                           # set to `require` in production
DB_EXPOSE_PORT=5432                          # host-mapped postgres port

# ── Redis (used by worker queue spine) ───────────────────────────────────────
# When running the full worker stack, add a `redis` service to docker-compose
# and point REDIS_ADDR at it.
REDIS_ADDR=redis:6379

# ── JWT ───────────────────────────────────────────────────────────────────────
JWT_SECRET=change-me-in-production-use-64-random-chars   # CHANGE IN PRODUCTION
JWT_EXPIRY_HOURS=24

# ── Port mapping (host → container) ──────────────────────────────────────────
BACKEND_PORT=8080
FRONTEND_PORT=3000

# ── Frontend build arg ────────────────────────────────────────────────────────
# Must be the URL the *browser* can reach at runtime — not the internal Docker
# hostname. For local docker-compose this is the host-mapped backend port.
NEXT_PUBLIC_API_URL=http://localhost:8080
